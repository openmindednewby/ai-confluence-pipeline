# =============================================================================
# AI Provider (choose one)
# =============================================================================
AI_PROVIDER=claude                    # claude | openai
ANTHROPIC_API_KEY=sk-ant-xxxxx        # Required if AI_PROVIDER=claude
OPENAI_API_KEY=sk-xxxxx               # Required if AI_PROVIDER=openai

# AI Model Configuration
AI_MODEL=claude-sonnet-4-6            # claude-opus-4-6, claude-sonnet-4-6, gpt-4o, etc.
AI_MAX_TOKENS=4096

# =============================================================================
# Confluence Configuration
# =============================================================================
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_SPACE_KEY=TECH              # Space where pages are created

# Optional: Parent page ID (pages will be nested under this)
CONFLUENCE_PARENT_PAGE_ID=

# =============================================================================
# Jira Configuration
# =============================================================================
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ                  # Project key for created tickets

# Optional: Default assignee, priority, etc.
JIRA_DEFAULT_ASSIGNEE=
JIRA_DEFAULT_PRIORITY=Medium
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_STORY_ISSUE_TYPE=Story
JIRA_SUBTASK_ISSUE_TYPE=Sub-task

# =============================================================================
# n8n Configuration (if self-hosting)
# =============================================================================
N8N_PORT=10353
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-this-to-a-random-string
WEBHOOK_URL=http://localhost:10353/webhook
